# Normalize line endings to LF in the repository
* text=auto eol=lf

# Force LF for shell scripts
*.sh text eol=lf

# Force CRLF on Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
